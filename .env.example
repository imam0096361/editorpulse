# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_OCR_MODEL="gemini-2.5-flash"
GEMINI_JUMP_MODEL="gemini-2.5-pro"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase backend integration
NEXT_PUBLIC_SUPABASE_URL="MY_SUPABASE_URL"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="MY_SUPABASE_PUBLISHABLE_KEY"
NEXT_PUBLIC_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"
SUPABASE_STORAGE_BUCKET="editorpulse-pages"
EDITORPULSE_API_KEY="MY_APP_SECRET"
ADMIN_USERNAME="MY_ADMIN_USERNAME"
ADMIN_PASSWORD="MY_ADMIN_PASSWORD"
ADMIN_SESSION_SECRET="MY_ADMIN_SESSION_SECRET"
